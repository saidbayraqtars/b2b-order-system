# Copy to .env at repo root and per-app as needed.

# ── Database (used by packages/database + web server) ──
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/b2b?schema=public"

# ── Auth.js v5 (web) ──
# Generate with: npx auth secret   (or openssl rand -base64 33)
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_TRUST_HOST="true"
