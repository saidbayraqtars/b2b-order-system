// packages/database/prisma/schema.prisma
// B2B Order & Management System — MVP schema (currency fixed to TRY in business logic).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN // whole system
  COMPANY_ADMIN // company manager
  COMPANY_STAFF // purchaser (may require approval)
  SALES_REP // plasiyer / field sales
}

enum OrderStatus {
  DRAFT
  PENDING_APPROVAL // waiting company-admin approval
  PENDING_CREDIT // credit limit exceeded, waiting super-admin approval
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REJECTED
}

enum PaymentMethod {
  OPEN_ACCOUNT // cari / açık hesap
  CREDIT_CARD
}

enum TransactionType {
  DEBIT // borç (order invoice)
  CREDIT // alacak (payment / refund)
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─────────────────────────────────────────────
// AUTH & RBAC
// ─────────────────────────────────────────────

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String
  phone        String?
  role         Role    @default(COMPANY_STAFF)
  isActive     Boolean @default(true)

  // Company staff/admin belong to a company. Super admin & sales rep are null.
  companyId String?
  company   Company? @relation("CompanyMembers", fields: [companyId], references: [id])

  // Sales rep portfolio (reverse of Company.salesRep)
  managedCompanies Company[] @relation("SalesRepPortfolio")

  ordersCreated  Order[]       @relation("OrderCreatedBy")
  ordersApproved Order[]       @relation("OrderApprovedBy")
  checkIns       CheckIn[]
  transactions   Transaction[] @relation("TransactionRecordedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([role])
}

// ─────────────────────────────────────────────
// COMPANY (CARİ)
// ─────────────────────────────────────────────

model Company {
  id        String  @id @default(cuid())
  name      String
  taxNumber String? @unique
  taxOffice String?
  email     String?
  phone     String?

  // Cari / limit
  creditLimit    Decimal @default(0) @db.Decimal(14, 2)
  currentBalance Decimal @default(0) @db.Decimal(14, 2) // cache derived from Transaction ledger
  currency       String  @default("TRY")

  // If true, COMPANY_STAFF orders go to PENDING_APPROVAL before credit check.
  requiresOrderApproval Boolean @default(false)

  isActive Boolean @default(true)

  customerGroupId String?
  customerGroup   CustomerGroup? @relation(fields: [customerGroupId], references: [id])

  salesRepId String?
  salesRep   User?   @relation("SalesRepPortfolio", fields: [salesRepId], references: [id])

  members      User[]            @relation("CompanyMembers")
  addresses    Address[]
  orders       Order[]
  transactions Transaction[]
  discounts    CompanyDiscount[]
  checkIns     CheckIn[]
  carts        Cart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerGroupId])
  @@index([salesRepId])
}

model Address {
  id         String  @id @default(cuid())
  companyId  String
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  label      String // "Merkez", "Depo"
  line1      String
  line2      String?
  city       String
  district   String?
  postalCode String?
  isDefault  Boolean @default(false)

  shippedOrders Order[]

  @@index([companyId])
}

// ─────────────────────────────────────────────
// CATALOG
// ─────────────────────────────────────────────

model CustomerGroup {
  id          String    @id @default(cuid())
  name        String    @unique // "Bayi", "Toptancı", "Zincir Market"
  description String?
  companies   Company[]
  prices      Price[]

  createdAt DateTime @default(now())
}

model Category {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  imageUrl String?

  // Tree (self relation)
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  products  Product[]
  discounts CompanyDiscount[]

  createdAt DateTime @default(now())

  @@index([parentId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  brand       String?
  images      String[] // URL list
  vatRate     Int      @default(20) // KDV % (TR: 1 / 10 / 20). Used for taxTotal calc.
  isActive    Boolean  @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  variants  ProductVariant[]
  discounts CompanyDiscount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model ProductVariant {
  id      String  @id @default(cuid())
  sku     String  @unique
  barcode String? @unique
  color   String?
  size    String?

  unitsPerCase Int  @default(1) // koli içi adet
  moqUnits     Int  @default(1) // minimum order quantity
  stock        Int  @default(0)
  weightGram   Int?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  prices     Price[]
  orderItems OrderItem[]
  cartItems  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([barcode])
}

// Price: variant × customer group × quantity tier.
// customerGroupId null = default list price.
model Price {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  customerGroupId String?
  customerGroup   CustomerGroup? @relation(fields: [customerGroupId], references: [id])

  minQuantity Int     @default(1) // tiered pricing threshold
  price       Decimal @db.Decimal(12, 2)
  currency    String  @default("TRY")

  @@unique([variantId, customerGroupId, minQuantity])
  @@index([variantId])
}

// Company-specific discount, by category OR product.
// INVARIANT (enforced in service layer): at least one of categoryId / productId must be set.
// Applied on top of the resolved group price.
model CompanyDiscount {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  discountType DiscountType @default(PERCENTAGE)
  value        Decimal      @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([categoryId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique // human-readable serial
  status        OrderStatus   @default(DRAFT)
  paymentMethod PaymentMethod @default(OPEN_ACCOUNT)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Placed by (staff OR sales rep)
  createdById String
  createdBy   User   @relation("OrderCreatedBy", fields: [createdById], references: [id])

  // Approved by (company admin or super admin)
  approvedById String?
  approvedBy   User?   @relation("OrderApprovedBy", fields: [approvedById], references: [id])

  shippingAddressId String?
  shippingAddress   Address? @relation(fields: [shippingAddressId], references: [id])

  // Totals — computed from item snapshots (price frozen at order time).
  subtotal      Decimal @default(0) @db.Decimal(14, 2)
  discountTotal Decimal @default(0) @db.Decimal(14, 2)
  taxTotal      Decimal @default(0) @db.Decimal(14, 2)
  grandTotal    Decimal @default(0) @db.Decimal(14, 2)
  currency      String  @default("TRY")

  note String?

  items        OrderItem[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([createdById])
  @@index([status])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  // Order-time snapshot (stable even if product/price changes later)
  productName String
  sku         String
  quantity    Int // total units
  caseCount   Int? // number of cases (if case-based)
  unitPrice   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  vatRate     Int     @default(20) // snapshot of Product.vatRate
  lineTotal   Decimal @db.Decimal(14, 2) // net of discount, excl. VAT

  @@index([orderId])
  @@index([variantId])
}

// ─────────────────────────────────────────────
// CARİ LEDGER
// ─────────────────────────────────────────────

model Transaction {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  type          TransactionType
  amount        Decimal         @db.Decimal(14, 2) // always positive; sign implied by type
  paymentMethod PaymentMethod? // set for payments/collections
  description   String?

  // Linked order if this debt originates from an order
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  // Sales rep / admin who recorded the collection
  recordedById String?
  recordedBy   User?   @relation("TransactionRecordedBy", fields: [recordedById], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([orderId])
}

// ─────────────────────────────────────────────
// SALES REP FIELD VISIT (CHECK-IN)
// ─────────────────────────────────────────────

model CheckIn {
  id         String  @id @default(cuid())
  salesRepId String
  salesRep   User    @relation(fields: [salesRepId], references: [id])
  companyId  String
  company    Company @relation(fields: [companyId], references: [id])

  latitude   Float?
  longitude  Float?
  checkInAt  DateTime  @default(now())
  checkOutAt DateTime?
  note       String?

  @@index([salesRepId])
  @@index([companyId])
}

// ─────────────────────────────────────────────
// CART (quick order / draft)
// ─────────────────────────────────────────────

model Cart {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Owner (staff or sales rep who is building this cart)
  ownerId String

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([ownerId])
}

model CartItem {
  id     String @id @default(cuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int

  @@unique([cartId, variantId])
}
